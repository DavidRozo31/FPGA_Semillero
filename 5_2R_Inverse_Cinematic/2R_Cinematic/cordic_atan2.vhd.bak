library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;
use work.cordic_pkg.ALL;

entity cordic_atan2 is
    Port (
        clk   : in  std_logic;
        rst   : in  std_logic;
        start : in  std_logic;
        x_in  : in  signed(15 downto 0);   -- CAMBIO: 32 → 16
        y_in  : in  signed(15 downto 0);   -- CAMBIO: 32 → 16
        angle : out signed(15 downto 0);   -- CAMBIO: 32 → 16
        done  : out std_logic
    );
end cordic_atan2;

architecture vectoring of cordic_atan2 is
    type data_array is array (0 to N_ITER) of signed(15 downto 0);  -- CAMBIO
    signal x_pipe     : data_array;
    signal y_pipe     : data_array;
    signal z_pipe     : data_array;
    signal valid_pipe : std_logic_vector(N_ITER downto 0);
    signal quad_corr  : signed(15 downto 0);                        -- CAMBIO

    -- PI en Q2.13: PI * 2^13 = 25736, -PI = -25736
    -- CAMBIO: los valores anteriores eran para Q2.30; estos son para Q2.13
    constant PI_POS : signed(15 downto 0) := to_signed(-25736, 16);
    constant PI_NEG : signed(15 downto 0) := to_signed(25736,  16);
begin
    process(clk, rst)
        variable x_scaled : signed(15 downto 0);
        variable y_scaled : signed(15 downto 0);
    begin
        if rst = '1' then
            x_pipe(0)     <= (others => '0');
            y_pipe(0)     <= (others => '0');
            z_pipe(0)     <= (others => '0');
            valid_pipe(0) <= '0';
            quad_corr     <= (others => '0');
        elsif rising_edge(clk) then
            if start = '1' then
                valid_pipe(0) <= '1';
                z_pipe(0)     <= (others => '0');
                -- CAMBIO: shift_right(x, 1) en vez de 2
                -- Con 16 bits y N_ITER=12 solo necesitamos 1 bit de guarda
                x_scaled := shift_right(x_in, 1);
                y_scaled := shift_right(y_in, 1);
                if x_in >= 0 then
                    x_pipe(0) <= x_scaled;
                    y_pipe(0) <= y_scaled;
                    quad_corr <= to_signed(0, 16);
                elsif y_in >= 0 then
                    x_pipe(0) <= -x_scaled;
                    y_pipe(0) <= -y_scaled;
                    quad_corr <= PI_POS;
                else
                    x_pipe(0) <= -x_scaled;
                    y_pipe(0) <= -y_scaled;
                    quad_corr <= PI_NEG;
                end if;
            else
                valid_pipe(0) <= '0';
            end if;
        end if;
    end process;

    GEN_VEC: for i in 0 to N_ITER-1 generate
        process(clk, rst)
            variable x_sh : signed(15 downto 0);   -- CAMBIO
            variable y_sh : signed(15 downto 0);   -- CAMBIO
        begin
            if rst = '1' then
                x_pipe(i+1)     <= (others => '0');
                y_pipe(i+1)     <= (others => '0');
                z_pipe(i+1)     <= (others => '0');
                valid_pipe(i+1) <= '0';
            elsif rising_edge(clk) then
                valid_pipe(i+1) <= valid_pipe(i);
                x_sh := shift_right(x_pipe(i), i);
                y_sh := shift_right(y_pipe(i), i);
                if y_pipe(i) >= 0 then
                    x_pipe(i+1) <= x_pipe(i) + y_sh;
                    y_pipe(i+1) <= y_pipe(i) - x_sh;
                    z_pipe(i+1) <= z_pipe(i) + ATAN_TABLE(i);
                else
                    x_pipe(i+1) <= x_pipe(i) - y_sh;
                    y_pipe(i+1) <= y_pipe(i) + x_sh;
                    z_pipe(i+1) <= z_pipe(i) - ATAN_TABLE(i);
                end if;
            end if;
        end process;
    end generate GEN_VEC;

    angle <= z_pipe(N_ITER) + quad_corr;
    done  <= valid_pipe(N_ITER);
end vectoring;