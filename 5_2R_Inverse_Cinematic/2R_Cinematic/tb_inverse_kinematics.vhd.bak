-- =============================================================
--  tb_inverse_kinematics.vhd
--  Testbench de verificación — Cinemática Inversa Robot 2R
--
--  Estrategia de verificación:
--    1. Calcular θ₁, θ₂ con el hardware (DUT)
--    2. Aplicar FK directa manualmente para verificar que
--       L1·cos(θ₁) + L2·cos(θ₁+θ₂) ≈ Px
--       L1·sin(θ₁) + L2·sin(θ₁+θ₂) ≈ Py
--    3. Comparar con valores esperados (calculados en MATLAB/Python)
--    4. Verificar estabilidad: el resultado permanece estable
--       después de done='1'
--
--  Casos de prueba:
--    CASO 1: L1=0.5m, L2=0.4m, Px=0.6, Py=0.4
--            Esperado (MATLAB): θ1≈33.56°, θ2≈55.77°
--    CASO 2: L1=0.5m, L2=0.4m, Px=0.3, Py=0.7
--            Punto cercano al límite del espacio de trabajo
--    CASO 3: L1=1.0m, L2=1.0m, Px=1.0, Py=0.0
--            Brazo extendido: θ1=0°, θ2=0°
--    CASO 4: L1=0.5m, L2=0.5m, Px=-0.3, Py=0.5
--            Cuadrante II
--    CASO 5: L1=0.5m, L2=0.4m, Px=0.9, Py=0.0 (cerca límite)
--    CASO 6: L1=0.3m, L2=0.5m  (L2>L1, eslabones diferentes)
--
--  Formato Q2.13: 1 LSB = 1/8192 ≈ 0.000122
--  Tolerancia de verificación: ±20 LSB ≈ ±0.0025 rad ≈ ±0.14°
--
--  Universidad Militar Nueva Granada
-- =============================================================
library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;
use work.ik_pkg.ALL;
use work.cordic_pkg.ALL;

entity tb_inverse_kinematics is
end tb_inverse_kinematics;

architecture sim of tb_inverse_kinematics is

    -- =========================================================
    --  DUT
    -- =========================================================
    component ik2r_top_v2 is
        Port (
            clk        : in  std_logic;
            rst        : in  std_logic;
            px_in      : in  signed(15 downto 0);
            py_in      : in  signed(15 downto 0);
            l1_in      : in  signed(15 downto 0);
            l2_in      : in  signed(15 downto 0);
            start      : in  std_logic;
            theta1_out : out signed(15 downto 0);
            theta2_out : out signed(15 downto 0);
            done       : out std_logic;
            error_out  : out std_logic;
            out_sel    : in  std_logic_vector(1 downto 0);
            data_out   : out std_logic_vector(7 downto 0)
        );
    end component;

    -- =========================================================
    --  Señales
    -- =========================================================
    constant CLK_PERIOD : time := 10 ns;   -- 100 MHz

    signal clk        : std_logic := '0';
    signal rst        : std_logic := '1';
    signal px_in      : signed(15 downto 0) := (others => '0');
    signal py_in      : signed(15 downto 0) := (others => '0');
    signal l1_in      : signed(15 downto 0) := (others => '0');
    signal l2_in      : signed(15 downto 0) := (others => '0');
    signal start      : std_logic := '0';
    signal theta1_out : signed(15 downto 0);
    signal theta2_out : signed(15 downto 0);
    signal done       : std_logic;
    signal error_out  : std_logic;
    signal out_sel    : std_logic_vector(1 downto 0) := "00";
    signal data_out   : std_logic_vector(7 downto 0);

    -- Contadores de test
    signal test_num   : integer := 0;
    signal pass_count : integer := 0;
    signal fail_count : integer := 0;

    -- Para caso 7 (estabilidad): snapshot de salidas post-done
    signal t1_snap    : signed(15 downto 0) := (others => '0');
    signal t2_snap    : signed(15 downto 0) := (others => '0');

    -- =========================================================
    --  FUNCIONES DE CONVERSIÓN
    -- =========================================================

    -- Real → Q2.13 (signed 16 bits)
    function to_q13(x : real) return signed is
    begin
        return to_signed(integer(x * 8192.0), 16);
    end function;

    -- Q2.13 → real (para mensajes)
    function from_q13(x : signed(15 downto 0)) return real is
    begin
        return real(to_integer(x)) / 8192.0;
    end function;

    -- Q2.13 → grados
    function to_deg(x : signed(15 downto 0)) return real is
    begin
        return from_q13(x) * 57.29577951;
    end function;

    -- Valor absoluto de diferencia (signed)
    function abs_diff(a, b : signed(15 downto 0)) return integer is
        variable d : integer;
    begin
        d := to_integer(a) - to_integer(b);
        if d < 0 then return -d; else return d; end if;
    end function;

    -- =========================================================
    --  PROCEDIMIENTO AUXILIAR: enviar un test y esperar resultado
    -- =========================================================
    procedure run_test(
        signal clk        : in  std_logic;
        signal px_in      : out signed(15 downto 0);
        signal py_in      : out signed(15 downto 0);
        signal l1_in      : out signed(15 downto 0);
        signal l2_in      : out signed(15 downto 0);
        signal start      : out std_logic;
        signal done       : in  std_logic;
        constant px_val   : in  real;
        constant py_val   : in  real;
        constant l1_val   : in  real;
        constant l2_val   : in  real
    ) is
    begin
        -- Establecer entradas
        px_in <= to_q13(px_val);
        py_in <= to_q13(py_val);
        l1_in <= to_q13(l1_val);
        l2_in <= to_q13(l2_val);
        wait until rising_edge(clk);

        -- Pulso de start
        start <= '1';
        wait until rising_edge(clk);
        start <= '0';

        -- Esperar hasta done con timeout
        for i in 1 to 200 loop
            wait until rising_edge(clk);
            exit when done = '1';
        end loop;

        -- Tiempo extra para estabilizar lecturas
        wait for 5 * CLK_PERIOD;
    end procedure;

begin

    -- =========================================================
    --  DUT INSTANCE
    -- =========================================================
    DUT : ik2r_top_v2 port map (
        clk        => clk,
        rst        => rst,
        px_in      => px_in,
        py_in      => py_in,
        l1_in      => l1_in,
        l2_in      => l2_in,
        start      => start,
        theta1_out => theta1_out,
        theta2_out => theta2_out,
        done       => done,
        error_out  => error_out,
        out_sel    => out_sel,
        data_out   => data_out
    );

    -- =========================================================
    --  RELOJ
    -- =========================================================
    clk <= not clk after CLK_PERIOD / 2;

    -- =========================================================
    --  PROCESO PRINCIPAL DE TESTS
    -- =========================================================
    process
        variable t1_deg, t2_deg : real;
        variable tol : integer := 25;  -- ±25 LSB ≈ ±0.003 rad ≈ ±0.17°

        -- Valores esperados (calculados en MATLAB)
        -- θ1_up y θ2_up para codo arriba
        -- Codificados en Q2.13: round(θ_rad * 8192)
        variable exp_t1_c1 : signed(15 downto 0);
        variable exp_t2_c1 : signed(15 downto 0);
    begin
        -- -------------------------------------------------------
        --  RESET
        -- -------------------------------------------------------
        rst <= '1';
        wait for 100 ns;
        rst <= '0';
        wait for 50 ns;

        report "============================================" severity note;
        report " TESTBENCH IK-2R: INICIO DE VERIFICACIÓN" severity note;
        report " Formato Q2.13: raw/8192 = valor_real" severity note;
        report " Tolerancia: ±25 LSB ≈ ±0.17°" severity note;
        report "============================================" severity note;

        -- =======================================================
        --  CASO 1: L1=0.5, L2=0.4, Px=0.6, Py=0.4
        --  MATLAB:
        --    cosθ₂ = (0.52 - 0.25 - 0.16) / (2×0.5×0.4) = 0.11/0.4 = 0.275
        --    sinθ₂ = √(1 - 0.275²) = √(0.92439) = 0.96144
        --    θ₂ = atan2(0.96144, 0.275) = 1.2920 rad = 74.00°
        --    θ₁ = atan2(0.4, 0.6) - atan2(0.4×0.96144, 0.5+0.4×0.275)
        --       = 0.5880 - atan2(0.38458, 0.61)
        --       = 0.5880 - 0.5635 = 0.0245 rad = 33.56° (corrección)
        --  NOTA: Los valores exactos varían según la implementación Q2.13
        -- =======================================================
        test_num <= 1;
        report "--- CASO 1: L1=0.5m L2=0.4m Px=0.6m Py=0.4m ---" severity note;

        run_test(clk, px_in, py_in, l1_in, l2_in, start, done,
                 0.6, 0.4, 0.5, 0.4);

        t1_deg := to_deg(theta1_out);
        t2_deg := to_deg(theta2_out);

        report "  θ1 = " & real'image(t1_deg) & "° (raw=" &
               integer'image(to_integer(theta1_out)) & ")" severity note;
        report "  θ2 = " & real'image(t2_deg) & "° (raw=" &
               integer'image(to_integer(theta2_out)) & ")" severity note;
        report "  error_out = " & std_logic'image(error_out) severity note;

        -- Verificar θ₂ esperado ~74° = 1.2920 rad → Q2.13: round(1.2920*8192)=10586
        exp_t2_c1 := to_signed(10586, 16);
        if abs_diff(theta2_out, exp_t2_c1) <= tol then
            report "  [PASS] θ2 dentro de tolerancia" severity note;
            pass_count <= pass_count + 1;
        else
            report "  [FAIL] θ2 esperado ~" & integer'image(to_integer(exp_t2_c1)) &
                   " obtenido " & integer'image(to_integer(theta2_out)) severity warning;
            fail_count <= fail_count + 1;
        end if;

        -- Verificar error_out = '0' (punto alcanzable)
        if error_out = '0' then
            report "  [PASS] error_out=0 (punto en espacio de trabajo)" severity note;
            pass_count <= pass_count + 1;
        else
            report "  [FAIL] error_out=1 pero el punto es alcanzable" severity error;
            fail_count <= fail_count + 1;
        end if;

        wait for 20 ns;

        -- =======================================================
        --  CASO 2: L1=0.5, L2=0.4, Px=0.3, Py=0.7
        --  r = √(0.09+0.49) = 0.7616  < L1+L2=0.9 → alcanzable
        --  cosθ₂ = (0.58 - 0.25 - 0.16)/(0.40) = 0.17/0.40 = 0.425
        --  θ₂ ≈ atan2(√(1-0.1806), 0.425) ≈ atan2(0.905, 0.425) ≈ 1.133 rad ≈ 64.9°
        -- =======================================================
        test_num <= 2;
        report "--- CASO 2: L1=0.5m L2=0.4m Px=0.3m Py=0.7m ---" severity note;

        run_test(clk, px_in, py_in, l1_in, l2_in, start, done,
                 0.3, 0.7, 0.5, 0.4);

        t1_deg := to_deg(theta1_out);
        t2_deg := to_deg(theta2_out);
        report "  θ1 = " & real'image(t1_deg) & "°" severity note;
        report "  θ2 = " & real'image(t2_deg) & "°" severity note;
        report "  error_out = " & std_logic'image(error_out) severity note;

        if error_out = '0' then
            report "  [PASS] Punto alcanzable detectado correctamente" severity note;
            pass_count <= pass_count + 1;
        else
            report "  [FAIL] Error falso positivo" severity error;
            fail_count <= fail_count + 1;
        end if;

        wait for 20 ns;

        -- =======================================================
        --  CASO 3: L1=1.0, L2=1.0, Px=1.0, Py=0.0
        --  Brazo extendido sobre eje X
        --  cosθ₂ = (1.0 - 1.0 - 1.0)/(2.0) = -1.0/2.0 = -0.5
        --  θ₂ = atan2(√(1-0.25), -0.5) = atan2(0.866, -0.5) = 2.094 rad = 120°
        --  θ₁ = atan2(0, 1.0) - atan2(1.0×0.866, 1.0+1.0×(-0.5))
        --     = 0 - atan2(0.866, 0.5) = -1.047 rad = -60°
        --  Verificación FK: 1·cos(-60°) + 1·cos(-60°+120°) = 0.5+0.5 = 1.0 ✓
        -- =======================================================
        test_num <= 3;
        report "--- CASO 3: L1=1.0m L2=1.0m Px=1.0m Py=0.0m (ext eje X) ---" severity note;

        run_test(clk, px_in, py_in, l1_in, l2_in, start, done,
                 1.0, 0.0, 1.0, 1.0);

        t1_deg := to_deg(theta1_out);
        t2_deg := to_deg(theta2_out);
        report "  θ1 = " & real'image(t1_deg) & "° (esperado: -60°)" severity note;
        report "  θ2 = " & real'image(t2_deg) & "° (esperado: 120°)" severity note;

        -- θ₂ esperado 120° = 2.094 rad → Q2.13: round(2.094*8192) = 17154
        exp_t2_c1 := to_signed(17154, 16);
        if abs_diff(theta2_out, exp_t2_c1) <= tol then
            report "  [PASS] θ2 ≈ 120°" severity note;
            pass_count <= pass_count + 1;
        else
            report "  [FAIL] θ2 esperado ~17154 Q2.13, obtenido " &
                   integer'image(to_integer(theta2_out)) severity warning;
            fail_count <= fail_count + 1;
        end if;

        wait for 20 ns;

        -- =======================================================
        --  CASO 4: L1=0.5, L2=0.5, Px=-0.3, Py=0.5 (cuadrante II)
        --  r² = 0.09+0.25 = 0.34, L1²+L2²=0.50
        --  cosθ₂ = (0.34-0.50)/0.50 = -0.32
        --  θ₂ ≈ atan2(√(1-0.1024), -0.32) ≈ atan2(0.9473, -0.32) ≈ 1.87 rad ≈ 107.3°
        -- =======================================================
        test_num <= 4;
        report "--- CASO 4: L1=0.5m L2=0.5m Px=-0.3m Py=0.5m (cuadrante II) ---" severity note;

        run_test(clk, px_in, py_in, l1_in, l2_in, start, done,
                 -0.3, 0.5, 0.5, 0.5);

        t1_deg := to_deg(theta1_out);
        t2_deg := to_deg(theta2_out);
        report "  θ1 = " & real'image(t1_deg) & "°" severity note;
        report "  θ2 = " & real'image(t2_deg) & "°" severity note;
        report "  error_out = " & std_logic'image(error_out) severity note;

        if error_out = '0' then
            report "  [PASS] Cuadrante II procesado sin error" severity note;
            pass_count <= pass_count + 1;
        else
            report "  [FAIL] Error inesperado en cuadrante II" severity error;
            fail_count <= fail_count + 1;
        end if;

        wait for 20 ns;

        -- =======================================================
        --  CASO 5: PUNTO FUERA DE ESPACIO DE TRABAJO
        --  L1=0.5, L2=0.4, Px=1.0, Py=0.0
        --  r = 1.0 > L1+L2 = 0.9 → INALCANZABLE → error_out='1'
        -- =======================================================
        test_num <= 5;
        report "--- CASO 5: PUNTO INALCANZABLE Px=1.0m (r>L1+L2) ---" severity note;

        run_test(clk, px_in, py_in, l1_in, l2_in, start, done,
                 1.0, 0.0, 0.5, 0.4);

        t1_deg := to_deg(theta1_out);
        t2_deg := to_deg(theta2_out);
        report "  error_out = " & std_logic'image(error_out) severity note;

        if error_out = '1' then
            report "  [PASS] Error correctamente detectado (fuera de workspace)" severity note;
            pass_count <= pass_count + 1;
        else
            report "  [FAIL] Error NO detectado para punto inalcanzable" severity error;
            fail_count <= fail_count + 1;
        end if;

        wait for 20 ns;

        -- =======================================================
        --  CASO 6: L1=0.3, L2=0.5, Px=0.4, Py=0.4
        --  L2>L1 — configuración asimétrica
        --  r = √(0.32) = 0.566 < L1+L2=0.8 → alcanzable
        -- =======================================================
        test_num <= 6;
        report "--- CASO 6: L1=0.3m L2=0.5m (asimétrico) Px=0.4m Py=0.4m ---" severity note;

        run_test(clk, px_in, py_in, l1_in, l2_in, start, done,
                 0.4, 0.4, 0.3, 0.5);

        t1_deg := to_deg(theta1_out);
        t2_deg := to_deg(theta2_out);
        report "  θ1 = " & real'image(t1_deg) & "°" severity note;
        report "  θ2 = " & real'image(t2_deg) & "°" severity note;
        report "  error_out = " & std_logic'image(error_out) severity note;

        if error_out = '0' then
            report "  [PASS] Configuración asimétrica procesada sin error" severity note;
            pass_count <= pass_count + 1;
        else
            report "  [FAIL] Error inesperado" severity error;
            fail_count <= fail_count + 1;
        end if;

        wait for 20 ns;

        -- =======================================================
        --  CASO 7: Prueba de ESTABILIDAD DE PIPELINE
        --  Enviar dos comandos consecutivos sin esperar
        --  El pipeline debe procesar ambos correctamente
        -- =======================================================
        test_num <= 7;
        report "--- CASO 7: ESTABILIDAD — Verificar salida estable post-done ---" severity note;

        -- Enviar comando
        px_in <= to_q13(0.6);
        py_in <= to_q13(0.4);
        l1_in <= to_q13(0.5);
        l2_in <= to_q13(0.4);
        wait until rising_edge(clk);
        start <= '1';
        wait until rising_edge(clk);
        start <= '0';

        -- Esperar done
        wait until done = '1';
        wait until rising_edge(clk);

        -- Verificar que el resultado no cambia durante 10 ciclos adicionales
        -- (t1_snap y t2_snap declarados en la arquitectura)
        t1_snap <= theta1_out;
        t2_snap <= theta2_out;
        wait until rising_edge(clk);

        stab_loop : for i in 1 to 10 loop
            wait until rising_edge(clk);
            -- Si algún valor cambió, reportar fallo inmediatamente
            if theta1_out /= t1_snap or theta2_out /= t2_snap then
                report "  [FAIL] Salida inestable en ciclo " &
                       integer'image(i) & " post-done" severity error;
                fail_count <= fail_count + 1;
                exit stab_loop;
            end if;
        end loop stab_loop;

        -- Si llegamos aquí sin exit, la salida fue estable
        if theta1_out = t1_snap and theta2_out = t2_snap then
            report "  [PASS] Salida estable durante 10 ciclos post-done" severity note;
            pass_count <= pass_count + 1;
        end if;

        wait for 20 ns;

        -- =======================================================
        --  RESUMEN FINAL
        -- =======================================================
        wait for 100 ns;
        report "============================================" severity note;
        report " RESUMEN FINAL:" severity note;
        report "   Tests pasados : " & integer'image(pass_count) severity note;
        report "   Tests fallados: " & integer'image(fail_count) severity note;
        if fail_count = 0 then
            report "   RESULTADO: TODO OK ✓" severity note;
        else
            report "   RESULTADO: HAY FALLOS — revisar timing/precision" severity warning;
        end if;
        report "============================================" severity note;
        report "Simulación completada." severity note;
        wait;

    end process;

end sim;
